<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Debug builds only: lets the app hit a plain-HTTP backend on the dev LAN
         (e.g. http://192.168.1.x:8000) without a network security config keyed to
         one specific IP that breaks every time the laptop's address changes.
         Release builds keep Android's secure default (cleartext HTTP blocked). -->
    <application android:usesCleartextTraffic="true" />

</manifest>
